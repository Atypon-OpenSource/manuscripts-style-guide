{
  "name": "@manuscripts/style-guide",
  "description": "Shared components for Manuscripts applications",
  "version": "3.5.26-LEAN-5586.0",
  "repository": "github:Atypon-OpenSource/manuscripts-style-guide",
  "license": "Apache-2.0",
  "main": "dist/cjs",
  "module": "dist/es",
  "types": "dist/types",
  "files": [
    "dist",
    "styles"
  ],
  "keywords": [
    "react"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "npm-run-all2 --parallel build:*",
    "build:cjs": "tsc --outDir dist/cjs --module commonjs",
    "build:es": "tsc --outDir dist/es --declarationDir dist/types --declaration",
    "build-storybook": "storybook build",
    "dev": "npm-run-all2 --parallel 'build:* --watch'",
    "lint": "eslint src stories --ext .ts,.tsx --max-warnings=0 --fix",
    "prebuild": "rimraf dist",
    "prettier": "prettier --write \"{src,stories}/**/*.{ts,tsx}\"",
    "preversion": "npm-run-all2 --parallel lint typecheck",
    "storybook": "storybook dev -p 6006",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "version": "pnpm build",
    "prepare": "husky"
  },
  "dependencies": {
    "@headlessui/react": "2.2.10",
    "formik": "2.4.9",
    "prosemirror-commands": "1.7.1",
    "prosemirror-history": "1.4.1",
    "prosemirror-keymap": "1.2.3",
    "prosemirror-model": "1.25.0",
    "prosemirror-state": "1.4.3",
    "prosemirror-view": "1.41.0",
    "react": "19.2.6",
    "react-datepicker": "^7.6.0",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "19.2.6",
    "react-router-dom": "5.3.4",
    "react-select": "5.10.2",
    "react-tooltip": "6.0.2",
    "styled-components": "5.3.11"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/preset-env": "7.29.5",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@fontsource/lato": "5.2.7",
    "@manuscripts/eslint-config": "0.5.1",
    "@storybook/addon-actions": "8.6.18",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/addon-interactions": "8.6.18",
    "@storybook/addon-links": "8.6.18",
    "@storybook/blocks": "8.6.18",
    "@storybook/react": "8.6.18",
    "@storybook/react-webpack5": "8.6.18",
    "@storybook/test": "8.6.18",
    "@types/lodash": "4.17.16",
    "@types/node": "^20.19.41",
    "@types/react": "19.2.14",
    "@types/react-datepicker": "^7.0.0",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "5.3.3",
    "@types/styled-components": "5.1.36",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "@vitest/coverage-v8": "4.1.6",
    "babel-loader": "10.1.1",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-diff": "2.1.7",
    "eslint-plugin-header": "3.1.1",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-mdx": "3.7.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-promise": "7.3.0",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-storybook": "10.3.6",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "storybook": "8.6.18",
    "typescript": "5.9.2",
    "vitest": "4.1.7"
  },
  "engines": {
    "node": ">=22"
  }
}